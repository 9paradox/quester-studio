{
	"id": "login-and-profile",
	"version": "v1",
	"name": "Login and profile (dummyjson)",
	"description": "POST login then GET /auth/me using the returned access token (dummyjson)",
	"nodes": [
		{
			"id": "start",
			"type": "start",
			"data": {
				"label": "Start"
			},
			"position": {
				"x": -264,
				"y": 8
			}
		},
		{
			"id": "input",
			"type": "input",
			"data": {
				"label": "Credentials"
			},
			"position": {
				"x": -7,
				"y": 12
			}
		},
		{
			"id": "login",
			"type": "http",
			"data": {
				"method": "POST",
				"url": "{{env.API_BASE}}/auth/login",
				"headers": {
					"Content-Type": "application/json"
				},
				"body": "{\"username\": \"{{input.username}}\", \"password\": \"{{input.password}}\"}",
				"label": "Login"
			},
			"position": {
				"x": 0,
				"y": 200
			}
		},
		{
			"id": "accessToken",
			"type": "extract",
			"data": {
				"expression": "body.accessToken",
				"label": "Access token"
			},
			"position": {
				"x": 321,
				"y": 227
			}
		},
		{
			"id": "profile",
			"type": "http",
			"data": {
				"method": "GET",
				"url": "{{env.API_BASE}}/auth/me",
				"headers": {
					"Authorization": "Bearer {{nodes.accessToken}}"
				},
				"label": "Profile"
			},
			"position": {
				"x": -3,
				"y": 369
			}
		},
		{
			"id": "assertStatus",
			"type": "assert",
			"data": {
				"checks": [
					{
						"path": "status",
						"equals": 200
					}
				],
				"label": "Assert 200"
			},
			"position": {
				"x": 295,
				"y": 432
			}
		},
		{
			"id": "extractAge",
			"type": "extract",
			"data": {
				"expression": "body.age",
				"label": "Extract age"
			},
			"position": {
				"x": 288,
				"y": 345
			}
		},
		{
			"id": "output",
			"type": "output",
			"data": {
				"label": "Result"
			},
			"position": {
				"x": 560,
				"y": 369
			}
		}
	],
	"edges": [
		{
			"id": "e0",
			"source": "start",
			"target": "input",
			"sourceHandle": null
		},
		{
			"id": "e1",
			"source": "input",
			"target": "login",
			"sourceHandle": null
		},
		{
			"id": "e2",
			"source": "login",
			"target": "accessToken",
			"sourceHandle": null
		},
		{
			"id": "e3",
			"source": "accessToken",
			"target": "profile",
			"sourceHandle": null
		},
		{
			"id": "e4",
			"source": "profile",
			"target": "assertStatus",
			"sourceHandle": null
		},
		{
			"id": "e5",
			"source": "profile",
			"target": "extractAge",
			"sourceHandle": null
		},
		{
			"id": "e6",
			"source": "profile",
			"target": "output",
			"sourceHandle": null
		}
	]
}
