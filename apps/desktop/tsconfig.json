{
	"extends": "@quester/tsconfig/base.json",
	"compilerOptions": {
		"jsx": "react-jsx",
		"noEmit": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/renderer/*"]
		}
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx",
		"vite.config.ts",
		"electrobun.config.ts"
	],
	"exclude": ["src/**/*.test.ts"]
}
