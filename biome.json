{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"organizeImports": { "enabled": true },
	"linter": { "enabled": true },
	"formatter": { "enabled": true, "indentStyle": "tab" },
	"files": {
		"ignore": [
			"dist",
			"node_modules",
			".turbo",
			".astro",
			"**/*.css",
			"apps/desktop/build",
			"schemas",
			".agents"
		]
	},
	"overrides": [
		{
			"include": ["**/renderer/components/ui/**"],
			"linter": {
				"rules": {
					"a11y": {
						"noLabelWithoutControl": "off"
					}
				}
			}
		}
	]
}
