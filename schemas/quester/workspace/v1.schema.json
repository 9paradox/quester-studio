{
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "const": "v1"
    },
    "flowsDir": {
      "type": "string",
      "default": "flows"
    },
    "environmentsDir": {
      "type": "string",
      "default": "environments"
    },
    "collectionsDir": {
      "type": "string",
      "default": "collections"
    }
  },
  "required": [
    "name",
    "version"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#"
}
